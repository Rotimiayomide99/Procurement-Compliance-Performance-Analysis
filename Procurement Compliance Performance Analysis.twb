      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0nwexr404d4xwf11ulxt90vdfhd9].[cnt:Savings:qk]&quot;' value='Total Transaction' />
        </aliases>
      </column>
      <column datatype='integer' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK([Calculation_1391748426727427])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Savings]) / TOTAL(SUM([Savings]))'>
          <table-calc ordering-type='Columns' />
        </calculation>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation3]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Quantity]) / TOTAL(SUM([Quantity]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Price' datatype='real' name='[Calculation_1391748423630849]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Unit_Price]*[Quantity])' />
      </column>
      <column caption='Avg Percentage Savings' datatype='real' name='[Calculation_1391748424531970]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG( ([Unit_Price] - [Negotiated_Price] ) / [Unit_Price] )' />
      </column>
      <column caption='Compliance Rate (%)' datatype='real' name='[Calculation_1391748426727427]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [Compliance] = &quot;Yes&quot; THEN 1 ELSE 0 END&#13;&#10;) / COUNT([Compliance])' />
      </column>
      <column caption='Compliance Distribution' datatype='string' name='[Calculation_1391748471472134]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Compliance2] = 1 THEN &quot;Compliant&quot;&#13;&#10;ELSE &quot;Non-Compliant&quot;&#13;&#10;END' />
      </column>
      <column caption='Lead Time (Days)' datatype='integer' name='[Calculation_1391748483010567]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Order_Date], [Delivery_Date])' />
      </column>
      <column caption='PO Count' datatype='integer' name='[Calculation_1391748568338440]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([PO_ID])' />
      </column>
      <column caption='Defective Units' datatype='integer' name='[Defective_Units]' role='measure' type='quantitative' />
      <column caption='Delivery Date' datatype='date' name='[Delivery_Date]' role='dimension' type='ordinal' />
      <column caption='Item Category' datatype='string' name='[Item_Category]' role='dimension' type='nominal' />
